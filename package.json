{
  "name": "virtual-diagnostic-simulator",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "clean": "rm -rf .next node_modules/.cache",
    "dev": "next dev -p 3000",
    "dev:turbo": "next dev -p 3000 --turbo",
    "dev:clean": "npm run clean && next dev -p 3000",
    "dev:fresh": "npm run clean && npx --yes kill-port 3000 && next dev -p 3000",
    "dev:safe": "npm run clean && cross-env NEXT_DEV_WEBPACK_NO_CACHE=1 next dev -p 3000",
    "build": "next build",
    "vercel-build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-resizable-panels": "^4.0.13"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2"
  }
}
