# Copy to .env.local for local development.

# PostgreSQL (required for Vercel and production — SQLite cannot run on serverless).
# Free options: Neon (https://neon.tech), Supabase, Vercel Postgres.
# Example Neon:
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth.js — use a long random string in production (e.g. openssl rand -base64 32)
AUTH_SECRET="use-a-long-random-string-at-least-32-chars"
AUTH_URL="http://localhost:3001"

RESEND_API_KEY=""
RESEND_FROM="VDS <onboarding@resend.dev>"
